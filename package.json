{
  "name": "icarry-sdk",
  "version": "0.1.0",
  "description": "Unofficial iCarry shipping & logistics API client for Node.js — type-safe, secure, zero dependencies",
  "author": "Zaytoun Solutions <info@zaytounsolutions.com>",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "SECURITY.md",
    "API_COVERAGE.md"
  ],
  "keywords": [
    "icarry",
    "shipping",
    "logistics",
    "shipment",
    "tracking",
    "courier",
    "delivery",
    "lebanon",
    "uae",
    "cod",
    "sdk",
    "api-client",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mohammad-AlBaker-Zaytoun/icarry-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/Mohammad-AlBaker-Zaytoun/icarry-sdk/issues"
  },
  "homepage": "https://github.com/Mohammad-AlBaker-Zaytoun/icarry-sdk#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "check:secrets": "node scripts/check-forbidden.mjs",
    "prepublishOnly": "npm run typecheck && npm run lint && npm run build && npm test"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "@vitest/coverage-v8": "^1.2.1",
    "eslint": "^8.56.0",
    "prettier": "^3.2.4",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^1.2.1"
  }
}
