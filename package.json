{
  "name": "icarry-sdk",
  "version": "0.1.5",
  "description": "Unofficial iCarry shipping & logistics API client for Node.js — type-safe, secure, zero dependencies",
  "author": "Zaytoun Solutions <info@zaytounsolutions.com>",
  "license": "MIT",
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "SECURITY.md",
    "API_COVERAGE.md"
  ],
  "keywords": [
    "icarry",
    "shipping",
    "logistics",
    "shipping-api",
    "logistics-api",
    "shipment-tracking",
    "courier",
    "delivery",
    "cash-on-delivery",
    "sdk",
    "typescript",
    "typescript-sdk",
    "api-client",
    "nodejs",
    "rest-api",
    "esm",
    "zero-dependencies",
    "lebanon",
    "uae",
    "ecommerce"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mohammad-AlBaker-Zaytoun/icarry-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/Mohammad-AlBaker-Zaytoun/icarry-sdk/issues"
  },
  "homepage": "https://github.com/Mohammad-AlBaker-Zaytoun/icarry-sdk#readme",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "typecheck": "tsc --noEmit",
    "test:types": "tsc -p tests/types/tsconfig.json",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"tests/**/*.ts\"",
    "check:secrets": "node scripts/check-forbidden.mjs",
    "smoke": "npm run smoke:dist",
    "smoke:dist": "node scripts/smoke.mjs",
    "smoke:package": "node scripts/smoke-package.mjs",
    "check:package": "node scripts/check-package.mjs",
    "validate": "npm run format:check && npm run lint && npm run typecheck && npm run test:types && npm run check:secrets && npm run test:coverage && npm run build && npm run check:package && npm run smoke:dist",
    "validate:release": "npm run validate && npm pack --dry-run && npm run smoke:package",
    "release:check": "npm run validate:release",
    "release:publish": "npm run release:check && npm publish",
    "prepublishOnly": "npm run validate"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "@vitest/coverage-v8": "^1.2.1",
    "eslint": "^8.56.0",
    "prettier": "^3.2.4",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^1.2.1"
  }
}
